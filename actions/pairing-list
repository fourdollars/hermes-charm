#!/bin/bash
# action: pairing-list ‚Äî show pending and approved pairing users

source "$(dirname "$0")/../hooks/common.sh"

OUTPUT=$(run_as_hermes_user "${HERMES_VENV}/bin/hermes pairing list" 2>&1 || true)
# Strip ANSI codes
CLEAN=$(echo "$OUTPUT" | sed $'s/\x1b\\[[0-9;]*m//g')
action_set "result=${CLEAN}"
