#!/bin/bash
# action: get-gateway-token — retrieve gateway auth token

source "$(dirname "$0")/../hooks/common.sh"

FORMAT=$(action_get format)
[ -z "$FORMAT" ] && FORMAT="text"

HERMES_DIR="${HERMES_HOME}/.hermes"

# Try to get token from hermes CLI
TOKEN=""
if [ -x "${HERMES_VENV}/bin/hermes" ]; then
    TOKEN=$(run_as_hermes_user "${HERMES_VENV}/bin/hermes gateway token" 2>/dev/null || echo "")
fi

# Fallback: try reading from config/auth files
if [ -z "$TOKEN" ]; then
    if [ -f "${HERMES_DIR}/auth.json" ]; then
        TOKEN=$(run_as_hermes_user "jq -r .gatewayToken // empty ${HERMES_DIR}/auth.json" 2>/dev/null || echo "")
    fi
fi

if [ -z "$TOKEN" ]; then
    action_fail "Could not retrieve gateway token. Is Hermes Agent properly configured?"
    exit 0
fi

GATEWAY_PORT=$(config_get gateway-port)
UNIT_IP=$(hostname -I | awk {print })

case "$FORMAT" in
    json)
        action_set "token=${TOKEN}"
        action_set "gateway-url=http://${UNIT_IP}:${GATEWAY_PORT}"
        action_set "dashboard-url=http://${UNIT_IP}:${GATEWAY_PORT}?token=${TOKEN}"
        ;;
    url)
        action_set "result=http://${UNIT_IP}:${GATEWAY_PORT}?token=${TOKEN}"
        ;;
    *)
        action_set "result=${TOKEN}"
        ;;
esac
