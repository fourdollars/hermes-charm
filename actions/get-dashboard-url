#!/bin/bash
# action: get-dashboard-url — start dashboard and return URL

source "$(dirname "$0")/../hooks/common.sh"

PORT=$(action_get port)
HOST=$(action_get host)
[ -z "$PORT" ] && PORT=9119
[ -z "$HOST" ] && HOST="127.0.0.1"

UNIT_IP=$(hostname -I | awk '{print $1}')

# Check if dashboard is already running
DASH_PID=$(pgrep -f "hermes dashboard" || true)

if [ -n "$DASH_PID" ]; then
    action_set "dashboard-url=http://${UNIT_IP}:${PORT}"
    action_set "local-url=http://127.0.0.1:${PORT}"
    action_set "status=already-running"
    action_set "pid=${DASH_PID}"
    action_set "ssh-tunnel=ssh -L ${PORT}:${UNIT_IP}:${PORT} <juju-machine-ip>"
    exit 0
fi

# Ensure dashboard dependencies are installed
log "Ensuring dashboard dependencies (fastapi, uvicorn)"
run_as_hermes_user "${HERMES_VENV}/bin/pip install fastapi uvicorn" >/dev/null 2>&1 || true

# Start dashboard — use --insecure if binding non-localhost
INSECURE_FLAG=""
if [ "$HOST" != "127.0.0.1" ] && [ "$HOST" != "localhost" ]; then
    INSECURE_FLAG="--insecure"
fi

log "Starting Hermes Dashboard on ${HOST}:${PORT}"
run_as_hermes_user "nohup ${HERMES_VENV}/bin/hermes dashboard --port ${PORT} --host ${HOST} --no-open --skip-build ${INSECURE_FLAG} > /tmp/hermes-dashboard.log 2>&1 &"
sleep 5

DASH_PID=$(pgrep -f "hermes dashboard" || true)

if [ -n "$DASH_PID" ]; then
    action_set "dashboard-url=http://${UNIT_IP}:${PORT}"
    action_set "local-url=http://127.0.0.1:${PORT}"
    action_set "status=started"
    action_set "pid=${DASH_PID}"
    if [ "$HOST" = "127.0.0.1" ] || [ "$HOST" = "localhost" ]; then
        action_set "note=Dashboard bound to localhost. Use SSH tunnel for remote access."
        action_set "ssh-tunnel=ssh -L ${PORT}:127.0.0.1:${PORT} <juju-machine-ip>"
    fi
else
    LOG_TAIL=$(tail -5 /tmp/hermes-dashboard.log 2>/dev/null || echo "no log")
    action_fail "Failed to start dashboard: ${LOG_TAIL}"
fi
