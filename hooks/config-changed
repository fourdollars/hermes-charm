#!/bin/bash
# config-changed hook — generate Hermes config from Juju options

source "$(dirname "$0")/common.sh"

status_set maintenance "Applying configuration"

MANUAL=$(config_get manual)

if [ "$MANUAL" = "true" ] || [ "$MANUAL" = "True" ]; then
    log "Manual mode enabled — skipping config generation"
    if is_service_active; then
        status_set active "Running (manual config)"
    else
        status_set waiting "Manual config mode — configure ~/.hermes/ manually"
    fi
    exit 0
fi

ensure_hermes_dir

# ---- Read config values ----
AI_PROVIDER=$(config_get ai-provider)
AI_MODEL=$(config_get ai-model)
AI_API_KEY=$(config_get ai-api-key)
AI_BASE_URL=$(config_get ai-base-url)
GATEWAY_PORT=$(config_get gateway-port)
TELEGRAM_TOKEN=$(config_get telegram-bot-token)
DISCORD_TOKEN=$(config_get discord-bot-token)
SLACK_BOT_TOKEN=$(config_get slack-bot-token)
SLACK_APP_TOKEN=$(config_get slack-app-token)
SIGNAL_PHONE=$(config_get signal-phone-number)
LINE_TOKEN=$(config_get line-channel-access-token)
LINE_SECRET=$(config_get line-channel-secret)
DM_POLICY=$(config_get dm-policy)
LOG_LEVEL=$(config_get log-level)
PERSONALITY=$(config_get personality)
SOUL_MD=$(config_get soul-md)
TERMINAL_BACKEND=$(config_get terminal-backend)
COMPRESSION=$(config_get compression-enabled)
MAX_TURNS=$(config_get max-turns)
ALLOW_ALL=$(config_get gateway-allow-all-users)
HA_URL=$(config_get home-assistant-url)
HA_TOKEN=$(config_get home-assistant-token)
MATRIX_HOMESERVER=$(config_get matrix-homeserver)
MATRIX_USER_ID=$(config_get matrix-user-id)
MATRIX_TOKEN=$(config_get matrix-access-token)
MATTERMOST_URL=$(config_get mattermost-url)
MATTERMOST_TOKEN=$(config_get mattermost-token)

# ---- Generate config.yaml ----
log "Generating config.yaml"

CONFIG_FILE="${HERMES_DIR}/config.yaml"

{
    echo "# Managed by Juju charm — manual edits will be overwritten on config-changed"

    # Model
    if [ -n "$AI_PROVIDER" ] && [ -n "$AI_MODEL" ]; then
        echo "model: ${AI_PROVIDER}/${AI_MODEL}"
    elif [ -n "$AI_MODEL" ]; then
        echo "model: ${AI_MODEL}"
    fi

    # Max turns
    echo "max_turns: ${MAX_TURNS}"

    # Personality
    if [ -n "$PERSONALITY" ]; then
        echo "personality: ${PERSONALITY}"
    fi

    # Terminal
    echo ""
    echo "terminal:"
    echo "  backend: ${TERMINAL_BACKEND}"

    # Compression
    echo ""
    echo "compression:"
    if [ "$COMPRESSION" = "true" ] || [ "$COMPRESSION" = "True" ]; then
        echo "  enabled: true"
    else
        echo "  enabled: false"
    fi

    # Gateway
    echo ""
    echo "gateway:"
    echo "  port: ${GATEWAY_PORT}"

    # Logging
    echo ""
    echo "logging:"
    echo "  level: ${LOG_LEVEL}"

    # Fallback providers (from ai0-ai9 slots)
    # Hermes uses a fallback chain in config.yaml
    FALLBACKS=""
    for i in $(seq 0 9); do
        slot_provider=$(config_get "ai${i}-provider")
        slot_model=$(config_get "ai${i}-model")
        if [ -n "$slot_provider" ] && [ -n "$slot_model" ]; then
            if [ -z "$FALLBACKS" ]; then
                FALLBACKS="yes"
                echo ""
                echo "fallback:"
            fi
            echo "  - provider: ${slot_provider}"
            echo "    model: ${slot_model}"
            # Include base_url if set
            slot_base_url=$(config_get "ai${i}-base-url")
            if [ -n "$slot_base_url" ]; then
                echo "    base_url: ${slot_base_url}"
            fi
        fi
    done

    # Custom endpoint (ai-base-url for primary)
    if [ -n "$AI_BASE_URL" ]; then
        echo ""
        echo "providers:"
        echo "  custom:"
        echo "    base_url: ${AI_BASE_URL}"
    fi

} > "/tmp/hermes-config.yaml"

run_as_hermes_user "cp /tmp/hermes-config.yaml ${CONFIG_FILE}"
rm -f /tmp/hermes-config.yaml

# ---- Generate SOUL.md if provided ----
if [ -n "$SOUL_MD" ]; then
    log "Writing custom SOUL.md"
    echo "$SOUL_MD" > /tmp/hermes-soul.md
    run_as_hermes_user "cp /tmp/hermes-soul.md ${HERMES_DIR}/SOUL.md"
    rm -f /tmp/hermes-soul.md
fi

# ---- Generate .env ----
log "Generating .env"

ENV_FILE="${HERMES_DIR}/.env"

# Helper: map provider name to env var name
provider_env_var() {
    local provider="$1"
    case "$provider" in
        anthropic)      echo "ANTHROPIC_API_KEY" ;;
        openai)         echo "OPENAI_API_KEY" ;;
        google|gemini)  echo "GOOGLE_API_KEY" ;;
        github-copilot) echo "COPILOT_GITHUB_TOKEN" ;;
        openrouter)     echo "OPENROUTER_API_KEY" ;;
        xai)            echo "XAI_API_KEY" ;;
        groq)           echo "GROQ_API_KEY" ;;
        deepseek)       echo "DEEPSEEK_API_KEY" ;;
        mistral)        echo "MISTRAL_API_KEY" ;;
        nous)           echo "NOUS_API_KEY" ;;
        novita)         echo "NOVITA_API_KEY" ;;
        huggingface|hf) echo "HF_TOKEN" ;;
        alibaba)        echo "DASHSCOPE_API_KEY" ;;
        minimax)        echo "MINIMAX_API_KEY" ;;
        minimax-cn)     echo "MINIMAX_CN_API_KEY" ;;
        zai)            echo "GLM_API_KEY" ;;
        kimi|kimi-coding) echo "KIMI_API_KEY" ;;
        *)              echo "" ;;
    esac
}

{
    echo "# Managed by Juju charm — manual edits will be overwritten on config-changed"

    # Primary AI provider key
    if [ -n "$AI_API_KEY" ]; then
        PRIMARY_VAR=$(provider_env_var "$AI_PROVIDER")
        if [ -n "$PRIMARY_VAR" ]; then
            echo "${PRIMARY_VAR}=${AI_API_KEY}"
        else
            # Unknown provider — use generic
            echo "AI_API_KEY=${AI_API_KEY}"
        fi
    fi

    if [ -n "$AI_BASE_URL" ]; then
        echo "AI_BASE_URL=${AI_BASE_URL}"
    fi

    # Additional AI slots (ai0 - ai9) — write provider-specific env vars
    # Hermes uses one env var per provider (not numbered slots)
    # If multiple slots use the same provider, last one wins
    for i in $(seq 0 9); do
        slot_provider=$(config_get "ai${i}-provider")
        slot_key=$(config_get "ai${i}-api-key")
        if [ -n "$slot_key" ] && [ -n "$slot_provider" ]; then
            SLOT_VAR=$(provider_env_var "$slot_provider")
            if [ -n "$SLOT_VAR" ]; then
                echo "${SLOT_VAR}=${slot_key}"
            fi
        fi
    done

    # Gateway access
    if [ "$ALLOW_ALL" = "true" ] || [ "$ALLOW_ALL" = "True" ]; then
        echo "GATEWAY_ALLOW_ALL_USERS=true"
    fi

    # Messaging tokens
    [ -n "$TELEGRAM_TOKEN" ] && echo "TELEGRAM_BOT_TOKEN=${TELEGRAM_TOKEN}"
    [ -n "$DISCORD_TOKEN" ] && echo "DISCORD_BOT_TOKEN=${DISCORD_TOKEN}"
    [ -n "$SLACK_BOT_TOKEN" ] && echo "SLACK_BOT_TOKEN=${SLACK_BOT_TOKEN}"
    [ -n "$SLACK_APP_TOKEN" ] && echo "SLACK_APP_TOKEN=${SLACK_APP_TOKEN}"
    [ -n "$SIGNAL_PHONE" ] && echo "SIGNAL_PHONE_NUMBER=${SIGNAL_PHONE}"
    [ -n "$LINE_TOKEN" ] && echo "LINE_CHANNEL_ACCESS_TOKEN=${LINE_TOKEN}"
    [ -n "$LINE_SECRET" ] && echo "LINE_CHANNEL_SECRET=${LINE_SECRET}"

    # Home Assistant
    [ -n "$HA_URL" ] && echo "HOME_ASSISTANT_URL=${HA_URL}"
    [ -n "$HA_TOKEN" ] && echo "HOME_ASSISTANT_TOKEN=${HA_TOKEN}"

    # Matrix
    [ -n "$MATRIX_HOMESERVER" ] && echo "MATRIX_HOMESERVER=${MATRIX_HOMESERVER}"
    [ -n "$MATRIX_USER_ID" ] && echo "MATRIX_USER_ID=${MATRIX_USER_ID}"
    [ -n "$MATRIX_TOKEN" ] && echo "MATRIX_ACCESS_TOKEN=${MATRIX_TOKEN}"

    # Mattermost
    [ -n "$MATTERMOST_URL" ] && echo "MATTERMOST_URL=${MATTERMOST_URL}"
    [ -n "$MATTERMOST_TOKEN" ] && echo "MATTERMOST_TOKEN=${MATTERMOST_TOKEN}"

} > "/tmp/hermes-env"

run_as_hermes_user "cp /tmp/hermes-env ${ENV_FILE} && chmod 600 ${ENV_FILE}"
rm -f /tmp/hermes-env

# ---- Ensure service is installed and manage lifecycle ----
if [ -z "$AI_PROVIDER" ] || [ -z "$AI_MODEL" ]; then
    status_set blocked "Missing AI provider or model configuration"
    exit 0
fi

if [ -z "$AI_API_KEY" ] && [ "$AI_PROVIDER" != "ollama" ]; then
    status_set blocked "Missing AI API key for provider: ${AI_PROVIDER}"
    exit 0
fi

# Install systemd service if not present
if ! systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null; then
    log "Installing Hermes Gateway systemd service"

    cat > "/etc/systemd/system/${SERVICE_NAME}" << UNITEOF
[Unit]
Description=Hermes Agent Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=${HERMES_USER}
Group=${HERMES_USER}
WorkingDirectory=${HERMES_HOME}
Environment=HOME=${HERMES_HOME}
Environment=PATH=${HERMES_VENV}/bin:${HERMES_HOME}/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=${HERMES_VENV}/bin/hermes gateway
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
UNITEOF

    systemctl daemon-reload
    systemctl enable "$SERVICE_NAME"
fi

# Restart or start the service
if is_service_active; then
    log "Restarting Hermes Gateway service"
    restart_service
else
    log "Starting Hermes Gateway service"
    start_service
fi

sleep 2

if is_service_active; then
    status_set active "Running (${AI_PROVIDER}/${AI_MODEL})"
else
    status_set blocked "Service failed to start — check: journalctl -u ${SERVICE_NAME}"
fi
